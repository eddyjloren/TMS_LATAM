# Base de datos PostgreSQL
DATABASE_URL="postgresql://usuario:password@localhost:5432/tms_db?schema=public"

# NextAuth
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="genera-una-cadena-aleatoria-segura-aqui"

# --- Timbrado CFDI (PAC) ---
# Por defecto el sistema corre en modo MOCK (timbrado simulado, sin costo,
# pensado para desarrollo). Para timbrar facturas reales ante el SAT necesitas
# contratar un PAC (Proveedor Autorizado de Certificación) autorizado, ya que
# el timbrado fiscal NO puede ser open source: es un servicio regulado por el SAT.
# El adaptador en src/lib/pac.ts es "plugable": puedes activar un proveedor
# real cambiando PAC_PROVIDER. Ejemplos de PACs con SDK/API documentada:
# Facturama, SW Sapien, Finkok, Solucion Factible.
PAC_PROVIDER="mock"
PAC_API_URL=""
PAC_API_USER=""
PAC_API_PASSWORD=""

# Certificados CSD (Certificado de Sello Digital) del emisor - requeridos para
# timbrado real. En modo mock no se usan.
CSD_CERT_PATH=""
CSD_KEY_PATH=""
CSD_KEY_PASSWORD=""

# --- Suscripción mensual (cobro SaaS a las empresas clientes) ---
# El cobro recurrente con tarjeta requiere un procesador de pagos regulado
# (no puede ser open source por ley). El adaptador en src/lib/billing.ts
# soporta modo "manual" (control interno de pagos) o "stripe" (modo test).
BILLING_PROVIDER="manual"
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
